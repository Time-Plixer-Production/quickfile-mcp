{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    // @cloudflare/workers-types provides all globals (fetch, crypto,
    // Request, Response, AbortController, setTimeout -> number, etc.)
    // Do NOT add "node" here — NodeJS.Timeout vs number breaks quickfile.ts.
    // Tests that need Node types use tsconfig.test.json.
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    // noEmit: Wrangler (esbuild) owns bundling — tsc is typecheck only.
    // Never run tsc to emit output; use wrangler build / wrangler deploy.
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
