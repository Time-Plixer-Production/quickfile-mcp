# npm configuration for quickfile-mcp
# ─────────────────────────────────────
# Ensures clean, predictable installs in CI and locally.

# Do not use deprecated legacy peer resolution — require correct peer deps
legacy-peer-deps=false

# Fail the install if Node/npm engine constraints in package.json are not met
engine-strict=true

# Save exact versions by default (no ^ or ~ drift)
save-exact=true
